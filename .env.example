# =========================================================================
# NovaStream — variables d'environnement (MODÈLE — aucun secret ici)
# =========================================================================
# Workflow :
#   1. cp .env.example .env
#   2. Remplir les vraies valeurs dans .env (jamais dans ce fichier)
#   3. docker compose build && docker compose up -d
#
# Les REACT_APP_* sont inlinées au BUILD du frontend.
# Pour les modifier : docker compose build && docker compose up -d
# =========================================================================

# ---- MongoDB (interne au stack) ----
MONGO_ROOT_USER=novastream
# Génère :  openssl rand -base64 32 | tr -d '/+=' | head -c 32
MONGO_ROOT_PASSWORD=CHANGE_ME_STRONG_SECRET
MONGO_DB_NAME=novastream

# ---- Supabase (REPRIS de LiveWatch — même projet) ----
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=CHANGE_ME
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME

# ---- CORS (domaine final côté navigateur) ----
CORS_ORIGINS=https://test.livewatch.top

# ---- Frontend (BUILD-TIME args) ----
REACT_APP_BACKEND_URL=https://test.livewatch.top
REACT_APP_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
REACT_APP_SUPABASE_ANON_KEY=CHANGE_ME

# ---- Backend tuning ----
# 1 worker = cache HLS 100% efficace (phase 1)
UVICORN_WORKERS=1
LOG_LEVEL=info
